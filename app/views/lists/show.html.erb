<div class="container">
  <div class="d-flex align-items-center justify-content-between my-3">
    <h1 class="m-0"><%= @list.name %></h1>
    <%= link_to "Add a movie", new_list_bookmark_path(@list), class:"btn btn-outline-success text-black" %>
  </div>

  <div class="row g-4 mb-4">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="col-4">
        <div class="border h-100 d-flex flex-column">
          <div class="border border-5 border-warning" style="background-image: url(<%= bookmark.movie.poster_url %>); height: 200px; background-position: center; background-size: cover;"></div>
          <div class="p-2 fs-6 d-flex flex-column flex-grow-1">
            <div class="d-flex gap-2 justify-content-between align-items-center mb-2">
              <p class="fw-bolder mb-0"><%= bookmark.movie.title %></p>
              <div class="d-flex align-items-center">
                <p class="mb-0"><%= bookmark.movie.rating %></p>
                <i class="fa-solid fa-star text-warning"></i>
              </div>
            </div>
            <p><%= bookmark.movie.overview %></p>
            <p class="mt-auto mb-0"><%= bookmark.comment %></p>
            <%= link_to "delete", bookmark_path(bookmark), class:"btn btn-outline-danger", data: {turbo_method: :delete, turbo_confirm: "Are you sur ?" } %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
